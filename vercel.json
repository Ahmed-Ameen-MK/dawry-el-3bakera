{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/abqari/:slug",
      "destination": "/api/abqari/:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|gif|svg|webp|css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
